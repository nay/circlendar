<div class="w-full">
  <%= render "back_links" %>
  <div class="flex flex-col sm:flex-row sm:justify-between items-start sm:items-center gap-4 mb-8">
    <h1 class="text-3xl font-bold text-gray-900"><%= t("announcements.show.title") %></h1>
    <div class="flex flex-wrap gap-2">
      <% unless @announcement.sent? %>
        <%= link_to t("announcements.show.edit"), edit_admin_announcement_path(@announcement), class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
        <%= button_to t("announcements.show.send_email"), send_email_admin_announcement_path(@announcement), method: :post, data: { turbo_confirm: t("announcements.show.confirm_send") }, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
      <% end %>
      <% if @delivery_counts&.dig("failed")&.positive? %>
        <%= button_to t("announcements.show.retry_failed"), retry_failed_admin_announcement_path(@announcement), method: :post, data: { turbo_confirm: t("announcements.show.confirm_retry") }, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-yellow-600 hover:bg-yellow-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-yellow-500" %>
      <% end %>
      <%= button_to t("announcements.show.delete"), admin_announcement_path(@announcement), method: :delete, data: { turbo_confirm: t("announcements.show.confirm_delete") }, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
    </div>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-lg">
    <div class="px-4 py-5 sm:px-6">
      <h3 class="text-lg leading-6 font-medium text-gray-900">
        <%= @announcement.subject %>
      </h3>
      <p class="mt-1 max-w-2xl text-sm text-gray-500">
        <% if @announcement.sent? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 whitespace-nowrap flex-shrink-0"><%= t("announcements.show.already_sent") %></span>
          <%= l(@announcement.sent_at, format: :long) %> に送信
        <% else %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800 whitespace-nowrap flex-shrink-0"><%= t("announcements.index.draft") %></span>
        <% end %>
      </p>
    </div>
    <div class="border-t border-gray-200">
      <dl>
        <% if @announcement.events.any? %>
          <div class="bg-gray-50 px-4 py-5 sm:px-6">
            <dt class="text-sm font-medium text-gray-500 mb-1"><%= Announcement.human_attribute_name(:event_ids) %></dt>
            <dd class="text-sm text-gray-900">
              <ul class="list-disc list-inside">
                <% @announcement.events.each do |event| %>
                  <li><%= link_to l(event.date, format: :long), admin_event_path(event), class: "text-blue-600 hover:text-blue-700" %></li>
                <% end %>
              </ul>
            </dd>
          </div>
        <% end %>

        <div class="bg-white px-4 py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500 mb-1"><%= Announcement.human_attribute_name(:body) %></dt>
          <dd class="text-sm text-gray-900 whitespace-pre-wrap"><%= simple_format(@announcement.body, {}, sanitize: true) %></dd>
        </div>

        <div class="bg-gray-50 px-4 py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500 mb-1">From</dt>
          <dd class="text-sm text-gray-900"><%= "#{Setting.instance.circle_name} <#{ENV.fetch('MAILER_FROM', 'noreply@example.com')}>" %></dd>
        </div>

        <div class="bg-white px-4 py-5 sm:px-6">
          <dt class="text-sm font-medium text-gray-500 mb-1"><%= Announcement.human_attribute_name(:to_address) %></dt>
          <dd class="text-sm text-gray-900"><%= @announcement.to_address %></dd>
        </div>

        <% if @deliveries.present? %>
          <div class="bg-white px-4 py-5 sm:px-6">
            <dt class="text-sm font-medium text-gray-500 mb-2"><%= Announcement.human_attribute_name(:recipient_addresses) %></dt>
            <dd>
              <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 text-sm">
                  <thead class="bg-gray-50">
                    <tr>
                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-500"><%= t("announcements.show.recipient") %></th>
                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-500"><%= t("announcements.show.sent_at") %></th>
                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-500"><%= t("announcements.show.status") %></th>
                      <th class="px-3 py-2 text-left text-xs font-medium text-gray-500"><%= t("announcements.show.error") %></th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                    <% grouped = @deliveries.chunk { |d| d.scheduled_at&.in_time_zone("Asia/Tokyo")&.to_date } %>
                    <% grouped.each do |_date, group| %>
                      <% group.each_with_index do |delivery, i| %>
                        <% member = @member_by_address[delivery.address] %>
                        <tr>
                          <td class="px-3 py-2 text-gray-900">
                            <% if member %>
                              <%= link_to member.name, admin_user_path(member.user), class: "text-blue-600 hover:text-blue-700" %>
                              <span class="text-gray-500 text-xs ml-2"><%= delivery.address %></span>
                            <% else %>
                              <%= delivery.address %>
                            <% end %>
                          </td>
                          <% if i == 0 %>
                            <td class="px-3 py-2 text-gray-900 align-top" rowspan="<%= group.size %>"><%= delivery.scheduled_at ? l(delivery.scheduled_at, format: :long) : delivery.requested_at ? l(delivery.requested_at, format: :long) : "" %></td>
                          <% end %>
                          <td class="px-3 py-2">
                            <% case delivery.status %>
                            <% when "requested" %>
                              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><%= t("announcements.show.status_requested") %></span>
                            <% when "pending" %>
                              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800"><%= t("announcements.show.status_pending") %></span>
                            <% when "failed" %>
                              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><%= t("announcements.show.status_failed") %></span>
                            <% end %>
                          </td>
                          <td class="px-3 py-2 text-red-600 text-xs"><%= delivery.error_message %></td>
                        </tr>
                      <% end %>
                    <% end %>
                  </tbody>
                </table>
              </div>
            </dd>
          </div>
        <% elsif @recipient_members %>
          <div class="bg-white px-4 py-5 sm:px-6">
            <dt class="text-sm font-medium text-gray-500 mb-1"><%= t("announcements.show.recipients") %></dt>
            <dd class="text-sm text-gray-900">
              <% if @announcement.recipient_addresses.present? %>
                <ul class="list-disc list-inside">
                  <% @recipient_members.each do |member| %>
                    <% member_emails = member.user.mail_addresses.select { |ma| @announcement.recipient_addresses.include?(ma.address) }.map(&:address) %>
                    <li>
                      <%= link_to member.name, admin_user_path(member.user), class: "text-blue-600 hover:text-blue-700" %>
                      <span class="text-gray-500">（<%= member_emails.join(", ") %>）</span>
                    </li>
                  <% end %>
                  <% orphan_emails = @announcement.recipient_addresses - @recipient_members.flat_map { |m| m.user.mail_addresses.map(&:address) } %>
                  <% orphan_emails.each do |email| %>
                    <li><%= email %></li>
                  <% end %>
                </ul>
              <% else %>
                <span class="text-gray-400">（なし）</span>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>
</div>
