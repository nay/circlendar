<div class="w-full max-w-2xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-8"><%= Setting.model_name.human %></h1>

  <%= form_with model: @setting, url: admin_setting_path, method: :patch, class: "space-y-6" do |form| %>
    <% if @setting.errors.any? %>
      <div class="rounded-md bg-red-50 p-4">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800"><%= t('errors.template.header') %></h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% @setting.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6 space-y-6">
        <div>
          <%= form.label :circle_name, Setting.human_attribute_name(:circle_name), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.text_field :circle_name, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>

        <hr class="border-gray-200">

        <div>
          <%= form.label :announcement_batch_size, Setting.human_attribute_name(:announcement_batch_size), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.number_field :announcement_batch_size, min: 1, class: "appearance-none block w-32 px-3 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>

        <div>
          <%= form.label :announcement_daily_quota_threshold, Setting.human_attribute_name(:announcement_daily_quota_threshold), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.number_field :announcement_daily_quota_threshold, min: 1, class: "appearance-none block w-32 px-3 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>

        <div>
          <%= form.label :announcement_retry_interval_hours, Setting.human_attribute_name(:announcement_retry_interval_hours), class: "block text-sm font-medium text-gray-700 mb-2" %>
          <%= form.number_field :announcement_retry_interval_hours, min: 1, class: "appearance-none block w-32 px-3 py-2 border border-gray-300 rounded-md shadow-sm bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" %>
        </div>
      </div>
    </div>

    <div class="flex justify-end">
      <%= form.submit "更新", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer" %>
    </div>
  <% end %>

  <hr class="my-8 border-gray-200">

  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6 space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">サインアップトークン</label>
        <% if @setting.signup_token.present? %>
          <div class="flex items-center gap-4">
            <code class="flex-1 px-3 py-2 bg-gray-100 border border-gray-300 rounded-md text-sm font-mono"><%= @setting.signup_token %></code>
            <button type="button" id="copy-signup-url-btn" onclick="navigator.clipboard.writeText('<%= signup_url(token: @setting.signup_token) %>').then(() => { this.textContent = 'コピーしました'; setTimeout(() => { this.textContent = 'サインアップURLをコピー'; }, 2000); })" class="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 cursor-pointer whitespace-nowrap">サインアップURLをコピー</button>
          </div>
          <p class="mt-2 text-sm text-gray-500">
            サインアップURL: <code class="px-1 py-0.5 bg-gray-100 rounded text-xs"><%= signup_url(token: @setting.signup_token) %></code>
          </p>
        <% else %>
          <div class="flex items-center gap-4">
            <span class="text-gray-500 text-sm">未発行</span>
            <%= button_to "トークンを発行", generate_signup_token_admin_setting_path, method: :post, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <% if @setting.signup_token.present? %>
    <hr class="my-8 border-gray-200">

    <div class="bg-white shadow sm:rounded-lg">
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-sm font-medium text-gray-700 mb-2">トークンの再発行</h3>
        <p class="text-sm text-gray-500 mb-4">トークンを再発行すると、現在のサインアップURLは無効になります。</p>
        <%= button_to "トークンを再発行", generate_signup_token_admin_setting_path, method: :post, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 cursor-pointer", data: { turbo_confirm: "トークンを再発行すると、古いサインアップURLは無効になります。よろしいですか？" } %>
      </div>
    </div>
  <% end %>
</div>
